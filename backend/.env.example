PORT = 8080
MONGO_URL = mongodb+srv://<username>:<password>@<cluster>/<database_name>
# Must be at least 32 characters (server refuses to start otherwise). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET = your_super_secret_string_at_least_32_characters_long
# Must be a DIFFERENT 32+ character string from JWT_SECRET (access vs refresh tokens use separate keys)
JWT_REFRESH_SECRET = your_other_super_secret_string_at_least_32_characters_long
AI_SERVICE_URL = https://postarticular-margret-majestically.ngrok-free.dev
GOOGLE_PLACES_API_KEY= your_google_places_api_key
OPENAI_API_KEY= your_openai_api_key
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
NODE_ENV=development