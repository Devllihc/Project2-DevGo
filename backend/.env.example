# Application Port
PORT=8080

# Environment (development, production)
NODE_ENV=development

# MongoDB Connection URL (Local or Atlas)
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>/<database_name>

# ----------------- AUTHENTICATION (JWT) -----------------
# Secret key for Access Token (Must be at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_string_at_least_32_characters_long

# Secret key for Refresh Token (Must be at least 32 characters, AND DIFFERENT from JWT_SECRET)
JWT_REFRESH_SECRET=your_other_super_secret_string_at_least_32_characters_long

# ----------------- AI & EXTERNAL APIs -----------------
# URL of the AI Server (e.g., Python server for AI tasks)
AI_SERVICE_URL=https://your-ai-service-url

# Google Places API Key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# OpenAI API Key (For AI Planner)
OPENAI_API_KEY=your_openai_api_key

# ----------------- CLIENT URLs (For CORS & Emails) -----------------
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ----------------- EMAIL CONFIGURATION (Resend) -----------------
# API Key from Resend dashboard (starts with re_)
RESEND_API_KEY=re_your_resend_api_key

# Sender address. Default Resend sandbox uses onboarding@resend.dev. 
# Once domain is verified in Resend, you can use any email under your domain.
EMAIL_FROM=DevGo <onboarding@resend.dev>

# Set to true to automatically verify user emails upon registration (useful for development/testing environments)
AUTO_VERIFY_EMAIL=false